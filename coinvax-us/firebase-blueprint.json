{
  "entities": {
    "User": {
      "title": "User",
      "description": "User profile and balance information.",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "email": { "type": "string", "format": "email" },
        "firstName": { "type": "string" },
        "lastName": { "type": "string" },
        "phone": { "type": "string" },
        "dob": { "type": "string" },
        "nationality": { "type": "string" },
        "address": { "type": "string" },
        "country": { "type": "string" },
        "occupation": { "type": "string" },
        "employer": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" },
        "balance": { "type": "number" },
        "outcomeMode": { "type": "string", "enum": ["normal", "force_loss", "force_profit"], "description": "Controls the outcome of user trades." },
        "allocations": {
          "type": "object",
          "properties": {
            "Main Account": { "type": "number" },
            "Trading Account": { "type": "number" },
            "Options Account": { "type": "number" },
            "P2P Account": { "type": "number" }
          }
        }
      },
      "required": ["uid", "email", "firstName", "lastName", "balance"]
    },
    "Trade": {
      "title": "Trade",
      "description": "A trading order placed by a user.",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "asset": { "type": "string", "enum": ["BTCUSDT", "ETHUSDT"] },
        "direction": { "type": "string", "enum": ["UP", "DOWN"] },
        "amount": { "type": "number" },
        "entryPrice": { "type": "number" },
        "exitPrice": { "type": "number" },
        "createdAt": { "type": "number" },
        "expiryTime": { "type": "number" },
        "status": { "type": "string", "enum": ["ACTIVE", "WON", "LOST", "TIE"] },
        "payout": { "type": "number" },
        "stopLossPct": { "type": "number" },
        "resolvedAt": { "type": "number" }
      },
      "required": ["uid", "asset", "direction", "amount", "entryPrice", "createdAt", "expiryTime", "status"]
    },
    "P2POrder": {
      "title": "P2POrder",
      "description": "A P2P buy or sell order.",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "userName": { "type": "string" },
        "type": { "type": "string", "enum": ["BUY", "SELL"] },
        "asset": { "type": "string" },
        "amount": { "type": "number" },
        "price": { "type": "number" },
        "status": { "type": "string", "enum": ["OPEN", "MATCHED", "COMPLETED", "CANCELLED"] },
        "matchedWith": { "type": "string", "description": "UID of the user who matched the order." },
        "paymentMethod": { "type": "string" },
        "createdAt": { "type": "number" },
        "updatedAt": { "type": "number" },
        "completionRate": { "type": "number" },
        "tradesCount": { "type": "number" },
        "typingStatus": { 
          "type": "object",
          "additionalProperties": { "type": "boolean" }
        }
      },
      "required": ["uid", "type", "asset", "amount", "price", "status", "createdAt"]
    },
    "ChatMessage": {
      "title": "ChatMessage",
      "description": "A message in a P2P chat.",
      "type": "object",
      "properties": {
        "orderId": { "type": "string" },
        "senderId": { "type": "string" },
        "text": { "type": "string" },
        "createdAt": { "type": "number" }
      },
      "required": ["orderId", "senderId", "text", "createdAt"]
    },
    "SupportTicket": {
      "title": "SupportTicket",
      "description": "A support ticket for a user.",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "userName": { "type": "string" },
        "status": { "type": "string", "enum": ["OPEN", "CLOSED"] },
        "lastMessage": { "type": "string" },
        "updatedAt": { "type": "number" }
      },
      "required": ["userId", "status", "updatedAt"]
    },
    "SupportMessage": {
      "title": "SupportMessage",
      "description": "A message in a support chat.",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "sender": { "type": "string", "enum": ["user", "agent"] },
        "text": { "type": "string" },
        "createdAt": { "type": "number" }
      },
      "required": ["userId", "sender", "text", "createdAt"]
    },
    "Withdrawal": {
      "title": "Withdrawal",
      "description": "A withdrawal request from a user.",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "amount": { "type": "number" },
        "method": { "type": "string" },
        "status": { "type": "string", "enum": ["PENDING", "APPROVED", "FREEZED", "CANCELED", "DISAPPROVED"] },
        "refunded": { "type": "boolean" },
        "notified": { "type": "boolean" },
        "createdAt": { "type": "number" },
        "updatedAt": { "type": "number" }
      },
      "required": ["uid", "amount", "method", "status", "createdAt"]
    },
    "Deposit": {
      "title": "Deposit",
      "description": "A deposit request from a user.",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "amount": { "type": "number" },
        "method": { "type": "string" },
        "status": { "type": "string", "enum": ["PENDING", "APPROVED", "DENIED"] },
        "notified": { "type": "boolean" },
        "createdAt": { "type": "number" },
        "updatedAt": { "type": "number" }
      },
      "required": ["uid", "amount", "method", "status", "createdAt"]
    },
    "Transfer": {
      "title": "Transfer",
      "description": "An internal transfer between user accounts.",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "fromAccount": { "type": "string" },
        "toAccount": { "type": "string" },
        "amount": { "type": "number" },
        "createdAt": { "type": "number" }
      },
      "required": ["uid", "fromAccount", "toAccount", "amount", "createdAt"]
    }
  },
  "firestore": {
    "/users/{uid}": {
      "schema": "User",
      "description": "Individual user profiles."
    },
    "/trades/{tradeId}": {
      "schema": "Trade",
      "description": "All trades placed by users."
    },
    "/p2p_orders/{orderId}": {
      "schema": "P2POrder",
      "description": "All P2P orders."
    },
    "/p2p_chats/{orderId}/messages/{messageId}": {
      "schema": "ChatMessage",
      "description": "Messages for a specific P2P order."
    },
    "/support_tickets/{userId}": {
      "schema": "SupportTicket",
      "description": "Support tickets for users."
    },
    "/support_tickets/{userId}/messages/{messageId}": {
      "schema": "SupportMessage",
      "description": "Messages for a user's support chat."
    },
    "/withdrawals/{withdrawalId}": {
      "schema": "Withdrawal",
      "description": "All withdrawal requests."
    },
    "/deposits/{depositId}": {
      "schema": "Deposit",
      "description": "All deposit requests."
    },
    "/transfers/{transferId}": {
      "schema": "Transfer",
      "description": "All internal transfers."
    },
    "/test/connection": {
      "schema": { "title": "TestConnection", "type": "object", "properties": {} },
      "description": "Path used to verify Firestore connectivity."
    }
  }
}
